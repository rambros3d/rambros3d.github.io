---
import LandingLayout from '../layouts/LandingLayout.astro';
---

<LandingLayout title="RamBros 3D — 3D Printable Scale Models" description="Dragon R1 RC car, X470 hydraulic excavator, model railway, and open source 3D printable scale models by RamBros." docsLink="/home/">

<section class="py-12 px-4">
	<div class="text-center max-w-4xl mx-auto">
		<img src="/rambros/rambros-dragon-logo/rambros-dragon.svg" alt="RamBros 3D" class="w-40 md:w-52 mx-auto drop-shadow-2xl mb-6" />
		<p class="text-3xl md:text-5xl text-base-content/70 mb-10 max-w-2xl mx-auto" style="font-family: 'Exo 2', sans-serif;">
		If it can be 3D printed,<br class="sm:hidden" /> it will be 3D printed.
	</p>
		<div class="flex flex-col items-center gap-6">
			<div class="text-center">
				<p class="text-xs font-semibold tracking-widest uppercase text-base-content/60 mb-3" style="font-family: 'Changa', sans-serif;">Follow Us</p>
				<div class="flex flex-wrap justify-center gap-3">
					<a href="https://www.youtube.com/@rambrosworkshop" target="_blank" rel="noopener" class="btn btn-neutral btn-depth rounded-full gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/></svg><span>YouTube</span></a>
					<a href="https://discord.com/invite/3CKbCmZ72G" target="_blank" rel="noopener" class="btn btn-neutral btn-depth rounded-full gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189z"/></svg><span>Discord</span></a>
					<a href="https://github.com/rambros3d" target="_blank" rel="noopener" class="btn btn-neutral btn-depth rounded-full gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg><span>GitHub</span></a>
				</div>
			</div>
			<div class="text-center">
				<p class="text-xs font-semibold tracking-widest uppercase text-base-content/60 mb-3" style="font-family: 'Changa', sans-serif;">Get Our Models</p>
				<div class="flex flex-wrap justify-center gap-3">
					<a href="https://www.printables.com/@rambros" target="_blank" rel="noopener" class="btn btn-neutral btn-depth rounded-full gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg><span>Printables</span></a>
					<a href="https://makerworld.com/en/@rambros" target="_blank" rel="noopener" class="btn btn-neutral btn-depth rounded-full gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg><span>MakerWorld</span></a>
					<a href="https://cults3d.com/en/users/RamBros/3d-models" target="_blank" rel="noopener" class="btn btn-neutral btn-depth rounded-full gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg><span>Cults3D</span></a>
				</div>
			</div>
		</div>
	</div>
</section>

<section class="py-16 px-4">
	<div class="max-w-4xl mx-auto">
		<div class="text-center mb-10">
			<p class="text-primary font-semibold tracking-wide uppercase text-sm mb-2">Our Work</p>
			<h2 class="text-3xl md:text-4xl font-bold" style="font-family: 'Belanosima', sans-serif;">Featured Models</h2>
		</div>
		<div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
			<a href="/dr/" class="group flex items-center gap-4 bg-base-200 rounded-xl p-3 transition-all duration-300 hover:shadow-lg hover:shadow-primary/10 hover:-translate-y-0.5">
				<img src="/images/image-5.png" alt="Dragon Railway" class="w-16 h-16 rounded-lg object-cover shrink-0 transition-transform duration-300 group-hover:scale-105" />
				<div class="min-w-0">
					<h3 class="font-bold text-sm truncate" style="font-family: 'Belanosima', sans-serif;">Dragon Railway</h3>
					<p class="text-xs text-base-content/50 truncate">Model railway ecosystem</p>
				</div>
			</a>
			<a href="https://youtu.be/dcK82xBHUmk" target="_blank" rel="noopener" class="group flex items-center gap-4 bg-base-200 rounded-xl p-3 transition-all duration-300 hover:shadow-lg hover:shadow-primary/10 hover:-translate-y-0.5">
				<img src="/images/image-3.png" alt="X470 Hydraulic Excavator" class="w-16 h-16 rounded-lg object-cover shrink-0 transition-transform duration-300 group-hover:scale-105" />
				<div class="min-w-0">
					<h3 class="font-bold text-sm truncate" style="font-family: 'Belanosima', sans-serif;">X470 Excavator</h3>
					<p class="text-xs text-base-content/50 truncate">3D printed hydraulics</p>
				</div>
			</a>
			<a href="https://makerworld.com/en/models/410845" target="_blank" rel="noopener" class="group flex items-center gap-4 bg-base-200 rounded-xl p-3 transition-all duration-300 hover:shadow-lg hover:shadow-primary/10 hover:-translate-y-0.5">
				<img src="/images/image-1.png" alt="Dragon R1" class="w-16 h-16 rounded-lg object-cover shrink-0 transition-transform duration-300 group-hover:scale-105" />
				<div class="min-w-0">
					<h3 class="font-bold text-sm truncate" style="font-family: 'Belanosima', sans-serif;">Dragon R1</h3>
					<p class="text-xs text-base-content/50 truncate">Open source RC car</p>
				</div>
			</a>
		</div>
	</div>
</section>

<section class="py-24 px-4">
	<div class="max-w-4xl mx-auto text-center">
		<p class="text-primary font-semibold tracking-wide uppercase text-sm mb-3">The Team</p>
		<h2 class="text-4xl md:text-5xl font-bold mb-4">About Us</h2>
		<p class="text-lg text-base-content/70 mb-10 max-w-2xl mx-auto">
			Two brothers from Tamil Nadu, South India. Hence the name — <strong>RamBros</strong>.
		</p>
		<div class="flex flex-col sm:flex-row justify-center gap-8 mb-10">
			<div class="flex-1 max-w-xs mx-auto sm:mx-0">
				<h3 class="text-xl font-bold mb-1">Mani Ram</h3>
				<p class="text-base-content/50 mb-4">CAD Designer</p>
				<a href="https://www.linkedin.com/in/maniram-rambros3d/" target="_blank" rel="noopener" class="btn btn-outline btn-sm">LinkedIn</a>
			</div>
			<div class="hidden sm:block w-px bg-base-300"></div>
			<div class="flex-1 max-w-xs mx-auto sm:mx-0">
				<h3 class="text-xl font-bold mb-1">Shree Ram</h3>
				<p class="text-base-content/50 mb-4">Hardware Designer</p>
				<a href="https://www.linkedin.com/in/shreeram-rambros-3d/" target="_blank" rel="noopener" class="btn btn-outline btn-sm">LinkedIn</a>
			</div>
		</div>
		<div class="bg-base-200 border border-base-content/10 rounded-2xl p-8 md:p-10 max-w-2xl mx-auto">
			<p class="text-2xl md:text-3xl font-semibold leading-snug mb-4" style="font-family: 'Belanosima', sans-serif;">
				Open Source First
			</p>
			<p class="text-base-content/60 leading-relaxed">
				We make our models open source because we benefit from other people's work, and we want others to benefit from ours. Every design we share is free to use, modify, and redistribute.
			</p>
		</div>
	</div>
</section>

</LandingLayout>
