---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  docsLink?: string;
}

const { title, description, docsLink } = Astro.props;
---

<html lang="en" data-theme="rambros-dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/svg+xml" href="/rambros/rambros-dragon-logo/rambros-dragon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://api.fonts.coollabs.io" crossorigin />
		<link href="https://api.fonts.coollabs.io/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
		<link href="https://api.fonts.coollabs.io/css2?family=Exo+2:wght@400;500;600;700&display=swap" rel="stylesheet" />
		<link href="https://api.fonts.coollabs.io/css2?family=Changa:wght@400;500;600;700&display=swap" rel="stylesheet" />
		<link href="https://api.fonts.coollabs.io/css2?family=Martian+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
		<title>{title ?? 'RamBros 3D'}</title>
		<meta name="description" content={description ?? 'If it can be 3D printed, it will be 3D printed.'} />
	</head>
	<body class="min-h-screen flex flex-col bg-base-300" style="font-family: var(--font-inter);">
		<Navbar docsLink={docsLink} />
		<div class="flex-1 flex flex-col">
			<slot />
		</div>
		<Footer />
		<script is:inline src="/theme.js"></script>
	</body>
</html>
