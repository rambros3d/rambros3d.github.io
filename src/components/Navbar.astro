---
interface Props {
  docsLink?: string;
}

const { docsLink = '/home/' } = Astro.props;
---
<header id="site-navbar" class="sticky top-0 inset-x-0 z-50">
  <input id="menu-toggle" type="checkbox" class="hidden peer" />
  <nav class="mx-auto mt-3 px-1 flex items-center w-fit rounded-full border border-base-300 bg-base-200/80 backdrop-blur-md shadow-lg py-1 transition-all duration-300 max-xs:w-full">
    <a href="/" class="flex items-center gap-2 pr-4 shrink-0">
      <img src="/rambros/rambros-dragon-logo/rambros-dragon.svg" alt="RamBros 3D" class="h-10 w-auto" />
      <span class="text-2xl" style="font-family: 'Belanosima', sans-serif;">RamBros</span>
    </a>
    <div class="flex items-center max-xs:hidden">
      <a href={docsLink} class="btn btn-ghost btn-sm !px-2 shrink-0">Docs</a>
      <button id="theme-toggle" class="btn btn-ghost btn-sm btn-circle shrink-0" aria-label="Toggle theme" type="button">
        <svg id="icon-sys" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        <svg id="icon-drk" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg id="icon-lgt" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      </button>
    </div>
    <label for="menu-toggle" class="btn btn-ghost btn-sm btn-circle shrink-0 ml-auto xs:hidden cursor-pointer" aria-label="Menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </label>
  </nav>
  <div class="xs:hidden max-h-0 overflow-hidden transition-all duration-300 mx-3 rounded-b-2xl border border-t-0 border-base-300 bg-base-200/95 backdrop-blur-md shadow-lg peer-checked:mt-2 peer-checked:p-3 peer-checked:max-h-60">
    <a href={docsLink} class="btn btn-ghost btn-sm !px-2 justify-start w-full">Docs</a>
    <div class="flex items-center gap-2 px-3 py-2">
      <span class="text-sm text-base-content/60">Theme</span>
      <button id="theme-toggle-m" class="btn btn-ghost btn-sm btn-circle" aria-label="Toggle theme" type="button">
        <svg id="icon-sys-m" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        <svg id="icon-drk-m" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg id="icon-lgt-m" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      </button>
    </div>
  </div>
</header>
